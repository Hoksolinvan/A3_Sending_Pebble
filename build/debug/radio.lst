1894:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** static void payload_integration( uint8_t *outBuffer, uint8_t *inBuffer, uint8_t size )
1895:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** {
1896:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     uint8_t prevInt = 0;
1897:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     uint8_t currBit;
1898:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     uint8_t index_bit;
1899:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     uint8_t index_byte;
1900:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     uint8_t index_bit_out;
1901:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     uint8_t index_byte_out;
1902:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     int32_t i = 0;
1903:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** 
1904:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     for( i = 0; i < size; i++ )
1905:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     {
1906:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* reverse all inputs */
1907:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         inBuffer[i] = ~inBuffer[i];
1908:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* init outBuffer */
1909:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         outBuffer[i] = 0;
1910:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     }
1911:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** 
1912:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     for( i = 0; i < ( size * 8 ); i++ )
1913:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     {
1914:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* index to take bit in inBuffer */
1915:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         index_bit = 7 - ( i % 8 );
1916:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         index_byte = i / 8;
1917:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* index to place bit in outBuffer is shifted 1 bit right */
1918:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         index_bit_out = 7 - ( ( i + 1 ) % 8 );
1919:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         index_byte_out = ( i + 1 ) / 8;
1920:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* extract current bit from input */
1921:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         currBit = ( inBuffer[index_byte] >> index_bit ) & 0x01;
1922:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* integration */
1923:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         prevInt ^= currBit;
ARM GAS  /tmp/ccTfOlJB.s 			page 47


1924:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         /* write result integration in output */
1925:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         outBuffer[index_byte_out] |= ( prevInt << index_bit_out );
1926:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     }
1927:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** 
1928:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     outBuffer[size] = ( prevInt << 7 ) | ( prevInt << 6 ) | ( ( ( !prevInt ) & 0x01 ) << 5 ) ;
1929:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** }
