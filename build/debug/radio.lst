  98:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****   */
  99:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** #ifndef DIVR
 100:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** #define DIVR( X, N )                ( ( ( X ) + ( ((X)>0?(N):(N))>>1 ) ) / ( N ) )
 101:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c **** #endif
