 318:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_uart_ex.c ****   *
 319:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_uart_ex.c **** @verbatim
