  77:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** /*!
  78:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  * @brief Calculates ceiling division of ( X / N )
  79:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  *
  80:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  * @param [in] X numerator
  81:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  * @param [in] N denominator
  82:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  *
  83:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  */
  84:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** #ifndef DIVC
  85:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** #define DIVC( X, N )                ( ( ( X ) + ( N ) - 1 ) / ( N ) )
  86:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** #endif /* DIVC */
  87:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** 
  88:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** /*!
ARM GAS  /tmp/ccxIxx01.s 			page 3


  89:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  * @brief Calculates rounding division of ( X / N )
  90:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  *
  91:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  * @param [in] X numerator
  92:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  * @param [in] N denominator
  93:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  *
  94:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c ****  */
  95:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** #ifndef DIVR
  96:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** #define DIVR( X, N )                ( ( ( X ) + ( ((X)>0?(N):(N))>>1 ) ) / ( N ) )
  97:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio_fw.c **** #endif /* DIVR */
