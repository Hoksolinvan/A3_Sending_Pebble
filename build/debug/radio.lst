 782:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         // When switching to BPSK mode the LoRa SyncWord register value is reset
 783:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         // Thus, we also reset the RadioPublicNetwork variable
