 761:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         // When switching to GFSK mode the LoRa SyncWord register value is reset
 762:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         // Thus, we also reset the RadioPublicNetwork variable
 763:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         SubgRf.PublicNetwork.Current = false;
 764:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         break;
 765:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     case MODEM_FSK:
 766:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         SUBGRF_SetPacketType( PACKET_TYPE_GFSK );
 767:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         // When switching to GFSK mode the LoRa SyncWord register value is reset
 768:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         // Thus, we also reset the RadioPublicNetwork variable
 769:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         SubgRf.PublicNetwork.Current = false;
 770:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         break;
 771:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     case MODEM_LORA:
