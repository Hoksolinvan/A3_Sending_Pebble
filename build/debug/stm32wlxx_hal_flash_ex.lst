  22:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****  ==============================================================================
  23:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****                    ##### Flash Extended features #####
  24:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****   ==============================================================================
  25:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  26:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****   [..] Comparing to other previous devices, the FLASH interface for STM32WLxx
  27:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        devices contains the following additional features
  28:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  29:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        (+) Capacity up to 256kB with single bank architecture supporting read-while-write
  30:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****            capability (RWW)
  31:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        (+) Single bank memory organization
  32:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        (+) PCROP protection
  33:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        (+) WRP protection
ARM GAS  /tmp/cclRXqpz.s 			page 2


  34:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        (+) CPU2 Security area
  35:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        (+) Program Erase Suspend feature
  36:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  37:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****                         ##### How to use this driver #####
  38:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****  ==============================================================================
  39:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****   [..] This driver provides functions to configure and program the FLASH memory
  40:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****        of all STM32WLxx devices. It includes
  41:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Flash Memory Erase functions:
  42:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****            (++) Lock and Unlock the FLASH interface using HAL_FLASH_Unlock() and
  43:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****                 HAL_FLASH_Lock() functions
  44:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****            (++) Erase function: Erase page, erase all sectors
  45:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****            (++) There are two modes of erase :
  46:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****              (+++) Polling Mode using HAL_FLASHEx_Erase()
  47:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****              (+++) Interrupt Mode using HAL_FLASHEx_Erase_IT()
  48:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  49:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Option Bytes Programming function: Use HAL_FLASHEx_OBProgram() to :
  50:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Set/Reset the write protection (per 4 KByte)
  51:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Set the Read protection Level
  52:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Program the user Option Bytes
  53:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Configure the PCROP protection (per 2 KByte)
  54:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Configure the IPCC Buffer start Address
  55:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Configure the CPU2 boot region and reset vector start Address
  56:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Configure the Flash and SRAM2 secure area
  57:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  58:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Get Option Bytes Configuration function: Use HAL_FLASHEx_OBGetConfig() to :
  59:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Get the value of a write protection area
  60:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Know if the read protection is activated
  61:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Get the value of the user Option Bytes
  62:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Get the value of a PCROP area
  63:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Get the IPCC Buffer start Address
  64:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Get the CPU2 boot region and reset vector start Address
  65:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Get the Flash and SRAM2 secure area
  66:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  67:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Flash Suspend, Allow functions:
  68:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****            (++) Suspend or Allow new program or erase operation request using HAL_FLASHEx_SuspendOp
  69:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****                 HAL_FLASHEx_AllowOperation() functions
  70:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  71:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Check is flash content is empty or not using HAL_FLASHEx_FlashEmptyCheck().
  72:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****           and modify this setting (for flash loader purpose e.g.) using
  73:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****           HAL_FLASHEx_ForceFlashEmpty().
  74:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  75:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Enable, Disable CPU2 debug access using HAL_FLASHEx_EnableC2Debug() or
  76:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****           HAL_FLASHEx_DisableC2Debug()
  77:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  78:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Enable Secure Hide Protection area access using HAL_FLASHEx_EnableSecHideProtection()
  79:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****          (++) Enable Secure Hide Protection area access done by hardware on a system reset
  80:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  81:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Privilege mode configuration function: Use HAL_FLASHEx_ConfigPrivMode()
  82:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) FLASH register can be protected against non-privilege accesses
  83:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  84:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****       (#) Get the privilege mode configuration function: Use HAL_FLASHEx_GetPrivMode()
  85:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****         (++) Returns if the FLASH registers are protected against non-privilege accesses
  86:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
  87:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****  @endverbatim
  88:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****   ******************************************************************************
  89:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c ****   */
  90:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_flash_ex.c **** 
