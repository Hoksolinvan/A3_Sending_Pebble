 234:Utilities/timer/stm32_timer.c ****       
 235:Utilities/timer/stm32_timer.c ****       if( TimerListHead == TimerObject ) /* Stop the Head */
 236:Utilities/timer/stm32_timer.c ****       {
 237:Utilities/timer/stm32_timer.c ****           TimerListHead->IsPending = 0;
 238:Utilities/timer/stm32_timer.c ****           if( TimerListHead->Next != NULL )
 239:Utilities/timer/stm32_timer.c ****           {
 240:Utilities/timer/stm32_timer.c ****             TimerListHead = TimerListHead->Next;
 241:Utilities/timer/stm32_timer.c ****             TimerSetTimeout( TimerListHead );
 242:Utilities/timer/stm32_timer.c ****           }
