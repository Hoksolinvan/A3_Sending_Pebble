{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build STM",
            "type": "shell",
            "command": "export PATH=/home/zgsdlv/.arduino15/packages/STMicroelectronics/tools/xpack-arm-none-eabi-gcc/14.2.1-1.1/bin:$PATH && cmake --preset Debug && cmake --build build/Debug",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Clean STM",
            "type": "shell",
            "command": "export PATH=/home/zgsdlv/.arduino15/packages/STMicroelectronics/tools/xpack-arm-none-eabi-gcc/14.2.1-1.1/bin:$PATH && cmake --preset Debug && cmake --build build/Debug --clean-first",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Flash STM",
            "type": "shell",
            "command": "openocd -f openocd.cfg -c \"program build/Debug/A3_Sending_Pebble.elf verify reset exit\"",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "dependsOn": "Build STM",
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
