 301:Utilities/misc/stm32_systime.c **** 
 302:Utilities/misc/stm32_systime.c ****   nbdays = DIVC( ( TM_DAYS_IN_YEAR * 3 + TM_DAYS_IN_LEAP_YEAR ) * year, 4 );
 303:Utilities/misc/stm32_systime.c **** 
