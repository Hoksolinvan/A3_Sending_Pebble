  42:Middlewares/Third_Party/FreeRTOS/Source/list.c ****  * defined for the header files above, but not in this file, in order to
  43:Middlewares/Third_Party/FreeRTOS/Source/list.c ****  * generate the correct privileged Vs unprivileged linkage and placement. */
  44:Middlewares/Third_Party/FreeRTOS/Source/list.c **** #undef MPU_WRAPPERS_INCLUDED_FROM_API_FILE /*lint !e961 !e750 !e9021. */
