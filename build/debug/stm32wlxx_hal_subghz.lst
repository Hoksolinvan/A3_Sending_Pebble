 752:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** /** @defgroup SUBGHZ_Exported_Functions_Group2 IO operation functions
 753:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****   *  @brief   Data transfers functions
 754:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****   *
 755:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** @verbatim
 756:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****   ==============================================================================
 757:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****                       ##### IO operation functions #####
 758:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****  ===============================================================================
 759:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****  [..]
 760:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****     This subsection provides a set of functions allowing to manage the SUBGHZ
 761:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****     data transfers.
 762:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** 
 763:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****     [..] The SUBGHZ supports Read and Write operation:
 764:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** 
 765:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****     (#) There are four modes of transfer:
 766:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****        (++) Set operation: The Set Command operation is performed in polling mode.
 767:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             The HAL status of command processing is returned by the same function
 768:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             after finishing transfer.
 769:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****        (++) Get operation: The Get Status operation is performed using polling mode
 770:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             These API update buffer in parameter to retrieve status of command.
 771:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             These API return the HAL status
 772:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****        (++) Write operation: The write operation is performed in polling mode.
 773:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             The HAL status of all data processing is returned by the same function
 774:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             after finishing transfer.
 775:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****        (++) Read operation: The read operation is performed using polling mode
 776:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****             These APIs return the HAL status.
 777:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** 
 778:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****     (#) Blocking mode functions are :
 779:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_ExecSetCmd(
 780:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_ExecGetCmd()
 781:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_WriteBuffer()
 782:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_ReadBuffer()
 783:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_WriteRegisters()
 784:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_ReadRegisters()
 785:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_WriteRegister()
 786:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****         (++) HAL_SUBGHZ_ReadRegister()
 787:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** 
 788:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** @endverbatim
 789:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****   * @{
 790:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c ****   */
 791:Drivers/STM32WLxx_HAL_Driver/Src/stm32wlxx_hal_subghz.c **** 
