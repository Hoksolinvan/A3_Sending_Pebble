 149:Utilities/timer/stm32_timer.c **** UTIL_TIMER_Status_t UTIL_TIMER_Start( UTIL_TIMER_Object_t *TimerObject)
 150:Utilities/timer/stm32_timer.c **** {
 151:Utilities/timer/stm32_timer.c ****   UTIL_TIMER_Status_t  ret = UTIL_TIMER_OK;
 152:Utilities/timer/stm32_timer.c ****   uint32_t elapsedTime;
 153:Utilities/timer/stm32_timer.c ****   uint32_t minValue;
 154:Utilities/timer/stm32_timer.c ****   uint32_t ticks;
 155:Utilities/timer/stm32_timer.c ****     
 156:Utilities/timer/stm32_timer.c ****   if(( TimerObject != NULL ) && ( TimerExists( TimerObject ) == false ) && (TimerObject->IsRunning 
 157:Utilities/timer/stm32_timer.c ****   {
 158:Utilities/timer/stm32_timer.c ****     UTIL_TIMER_ENTER_CRITICAL_SECTION();
 159:Utilities/timer/stm32_timer.c ****     ticks = TimerObject->ReloadValue;
 160:Utilities/timer/stm32_timer.c ****     minValue = UTIL_TimerDriver.GetMinimumTimeout( );
 161:Utilities/timer/stm32_timer.c ****     
 162:Utilities/timer/stm32_timer.c ****     if( ticks < minValue )
 163:Utilities/timer/stm32_timer.c ****     {
 164:Utilities/timer/stm32_timer.c ****       ticks = minValue;
 165:Utilities/timer/stm32_timer.c ****     }
 166:Utilities/timer/stm32_timer.c ****     
 167:Utilities/timer/stm32_timer.c ****     TimerObject->Timestamp = ticks;
 168:Utilities/timer/stm32_timer.c ****     TimerObject->IsPending = 0U;
 169:Utilities/timer/stm32_timer.c ****     TimerObject->IsRunning = 1U;
 170:Utilities/timer/stm32_timer.c ****     TimerObject->IsReloadStopped = 0U;
 171:Utilities/timer/stm32_timer.c ****     if( TimerListHead == NULL )
 172:Utilities/timer/stm32_timer.c ****     {
 173:Utilities/timer/stm32_timer.c ****       UTIL_TimerDriver.SetTimerContext();
 174:Utilities/timer/stm32_timer.c ****       TimerInsertNewHeadTimer( TimerObject ); /* insert a timeout at now+obj->Timestamp */
 175:Utilities/timer/stm32_timer.c ****     }
 176:Utilities/timer/stm32_timer.c ****     else 
 177:Utilities/timer/stm32_timer.c ****     {
 178:Utilities/timer/stm32_timer.c ****       elapsedTime = UTIL_TimerDriver.GetTimerElapsedTime( );
 179:Utilities/timer/stm32_timer.c ****       TimerObject->Timestamp += elapsedTime;
