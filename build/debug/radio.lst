 776:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****             SubgRf.PublicNetwork.Current = SubgRf.PublicNetwork.Previous;
 777:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****             RadioSetPublicNetwork( SubgRf.PublicNetwork.Current );
 778:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         }
 779:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****         break;
 780:Middlewares/Third_Party/SubGHz_Phy/radio_driver/radio.c ****     case MODEM_BPSK:
