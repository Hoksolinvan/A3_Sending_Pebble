 219:Utilities/timer/stm32_timer.c **** UTIL_TIMER_Status_t UTIL_TIMER_Stop( UTIL_TIMER_Object_t *TimerObject )
 220:Utilities/timer/stm32_timer.c **** {
 221:Utilities/timer/stm32_timer.c ****   UTIL_TIMER_Status_t  ret = UTIL_TIMER_OK;
 222:Utilities/timer/stm32_timer.c **** 
 223:Utilities/timer/stm32_timer.c ****   if (NULL != TimerObject)
 224:Utilities/timer/stm32_timer.c ****   {
 225:Utilities/timer/stm32_timer.c ****     UTIL_TIMER_ENTER_CRITICAL_SECTION();
 226:Utilities/timer/stm32_timer.c ****     UTIL_TIMER_Object_t* prev = TimerListHead;
 227:Utilities/timer/stm32_timer.c ****     UTIL_TIMER_Object_t* cur = TimerListHead;
